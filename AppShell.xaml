<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Monsters_Inc_bezorgerApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Monsters_Inc_bezorgerApp"
    Title="Monsters_Inc_bezorgerApp">

    <TabBar>
        <!-- Tab 1: Home -->
        <Tab Title="Home" Icon="home.png">
            <ShellContent
            ContentTemplate="{DataTemplate local:HomePage}"
            Route="HomePage" />
        </Tab>

        <!-- Tab 2: Route -->
        <Tab Title="Route" Icon="location.png">
            <ShellContent
            ContentTemplate="{DataTemplate local:RoutePage}"
            Route="RoutePage" />
        </Tab>

        <!-- Tab 3: Pakketten inscannen -->
        <Tab Title="Pakketten inscannen" Icon="box.png">
            <ShellContent
            ContentTemplate="{DataTemplate local:StopsPage}"
            Route="StopsPage" />
        </Tab>
    </TabBar>


</Shell>
