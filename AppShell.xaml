<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Monsters_Inc_bezorgerApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Monsters_Inc_bezorgerApp"
    Title="Monsters_Inc_bezorgerApp">

    <TabBar>
        <ShellContent
            Title="Route"
            ContentTemplate="{DataTemplate local:AllOrders}"
            Icon="location.png"
            Route="AllOrders" />

        <ShellContent
            Title="Home"
            ContentTemplate="{DataTemplate local:InProgressOrdersPage}"
            Icon="home.png"
            Route="InProgressOrdersPage" />

        <ShellContent
            Title="Paketten"
            ContentTemplate="{DataTemplate local:FinishedOrdersPage}"
            Icon="box.png"
            Route="FinishedOrdersPage" />
    </TabBar>

</Shell>
