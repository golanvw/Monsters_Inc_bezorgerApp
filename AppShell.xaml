<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Monsters_Inc_bezorgerApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Monsters_Inc_bezorgerApp"
    Title="Monsters_Inc_bezorgerApp">

    <TabBar>
        <ShellContent
            Title="Route"
            ContentTemplate="{DataTemplate local:RoutePage}"
            Icon="location.png"
            Route="RoutePage" />

        <ShellContent
            Title="Home"
            ContentTemplate="{DataTemplate local:HomePage}"
            Icon="home.png"
            Route="HomePage" />

        <ShellContent
            Title="Stops"
            ContentTemplate="{DataTemplate local:StopsPage}"
            Icon="box.png"
            Route="StopsPage" />
    </TabBar>

</Shell>
